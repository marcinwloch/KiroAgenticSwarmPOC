# AWS AgentCore Runtime Endpoints (Nortal Kiro Swarm PoC)
#
# These are non-secret values (no credentials). Copy into .kiro/settings/mcp.json
# as env vars for the MCP server. See README.md for details.

# AgentCore Runtime ARN — the swarm supervisor runs here on AWS account 395833164797
SWARM_AGENTCORE_ENDPOINT=arn:aws:bedrock-agentcore:eu-central-1:395833164797:runtime/nortal_swarm_runtime-xY5ryV6JbB

# AgentCore Memory ARN — persistent multi-turn context storage
SWARM_MEMORY_ARN=arn:aws:bedrock-agentcore:eu-central-1:395833164797:memory/swarm_memory-ESsFsWEyZy

# AgentCore Gateway OAuth endpoint (Cognito for M2M auth to invoke swarm)
SWARM_GATEWAY_URL=https://nortal-swarm-gateway-onelyg3h15.gateway.bedrock-agentcore.eu-central-1.amazonaws.com/mcp

# DynamoDB table for session state + judge outputs
SWARM_SESSIONS_TABLE=swarm-sessions

# AWS region
AWS_REGION=eu-central-1

# Optional: timeouts (in seconds) for swarm invocations
SWARM_INVOKE_TIMEOUT_SEC=900
SWARM_STAGE_TIMEOUT_SEC=300

